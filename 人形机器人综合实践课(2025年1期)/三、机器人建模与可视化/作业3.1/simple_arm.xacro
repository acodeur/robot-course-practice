<robot name="simple_arm_xacro"
  xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="base_length" value="0.1" />
  <xacro:property name="base_radius" value="0.2" />
  <xacro:property name="link1_length" value="0.4" />
  <xacro:property name="link2_length" value="0.3" />

  <!-- 定义颜色，用于rviz显示 -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>
  <!-- 基座 -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="${base_length}" radius="${base_radius}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="${base_length}" radius="${base_radius}"/>
      </geometry>
    </collision>
  </link>
  <!-- 连杆1 -->
  <link name="link_1">
    <visual>
      <geometry>
        <box size="0.1 0.1 ${link1_length}"/>
      </geometry>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 ${link1_length}"/>
      </geometry>
      <origin xyz="0 0 ${link1_length/2}" />
    </collision>
  </link>
  <!-- 节点1（连接基座和连杆1） -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link" />
    <child link="link_1" />
    <origin xyz="0 0 ${base_length/2}" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-1.0" upper="1.0" effort="10" velocity="1"/>
  </joint>
  <!-- 连杆2 -->
  <link name="link_2">
    <visual>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="${link2_length}" />
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="${link2_length}" />
      </geometry>
    </collision>
  </link>
  <!-- 节点2（连接连杆1和连杆2） -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1" />
    <child link="link_2" />
    <origin xyz="0 0 ${link1_length}" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-${pi/2}" upper="${pi/2}" effort="10" velocity="1"/>
  </joint>
</robot>